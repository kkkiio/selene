{
  "format_version": 1,
  "source": "examples/survivors/survivors.xaml",
  "output": "examples/wasm-component/component/gen/interface/selene/survivors_ui/survivorsUiApi/view.generated.mbt",
  "state_type": "SurvivorsUiState",
  "mount_function": "generated_full_mount",
  "bindings": {
    "levelLabel": {
      "expression": "\"Level: \" + state.level.to_string()",
      "dependencies": ["level"]
    },
    "experienceLabel": {
      "expression": "\"EXP: \" + state.experience.to_string() + \"/\" + state.experience_goal.to_string()",
      "dependencies": ["experience", "experience_goal"]
    },
    "waveLabel": {
      "expression": "\"Wave: \" + state.wave.to_string()",
      "dependencies": ["wave"]
    },
    "scoreLabel": {
      "expression": "\"Score: \" + state.score.to_string()",
      "dependencies": ["score"]
    },
    "timerLabel": {
      "expression": "\"Time: \" + (state.remaining_seconds / 60).to_string() + \":\" + (state.remaining_seconds % 60).to_string().pad_start(2, '0')",
      "dependencies": ["remaining_seconds"]
    },
    "levelUpVisible": {
      "expression": "state.level_up_visible",
      "dependencies": ["level_up_visible"]
    },
    "gameOverVisible": {
      "expression": "state.game_over_visible",
      "dependencies": ["game_over_visible"]
    },
    "gameOverTitle": {
      "expression": "if state.victory { \"VICTORY!\" } else { \"GAME OVER\" }",
      "dependencies": ["victory"]
    },
    "finalScoreLabel": {
      "expression": "\"Final Score: \" + state.score.to_string()",
      "dependencies": ["score"]
    },
    "selections": {
      "expression": "state.selections",
      "dependencies": ["selections"]
    }
  },
  "collections": {
    "selections": {
      "item_variable": "selection",
      "key_expression": "selection.key",
      "key_prefix": "selection:"
    }
  }
}
