// Generated from examples/survivors/survivors.xaml. The WIT bindings beside this
// file are regenerated by `just build-wasm-component`.

///|
priv struct SurvivorsUiRecord {
  state : SurvivorsUiState
}

///|
let survivors_ui_states : Map[UInt, SurvivorsUiRecord] = Map([])

///|
fn state_mutations(
  previous : SurvivorsUiState,
  next : SurvivorsUiState,
  selections_replaced : Bool,
) -> Array[@tree.TreeMutation] {
  let mutations : Array[@tree.TreeMutation] = []
  let text_values = [
    (previous.level != next.level, "level", "Level: " + next.level.to_string()),
    (
      previous.experience != next.experience ||
      previous.experience_goal != next.experience_goal,
      "experience",
      "EXP: " +
      next.experience.to_string() +
      "/" +
      next.experience_goal.to_string(),
    ),
    (previous.wave != next.wave, "wave", "Wave: " + next.wave.to_string()),
    (previous.score != next.score, "score", "Score: " + next.score.to_string()),
    (
      previous.remaining_seconds != next.remaining_seconds,
      "timer",
      "Time: " +
      (next.remaining_seconds / 60).to_string() +
      ":" +
      (next.remaining_seconds % 60).to_string().pad_start(2, '0'),
    ),
  ]
  for entry in text_values {
    let (changed, key, value) = entry
    if changed {
      mutations.push(SetText({ key, value }))
    }
  }
  if previous.level_up_visible != next.level_up_visible {
    if next.level_up_visible {
      let mounted = generated_full_mount({ ..next, game_over_visible: false })
      let included : Map[String, Bool] = Map([])
      for mutation in mounted {
        match mutation {
          Mount(spec) => {
            let parent_included = match spec.parent {
              Some(parent) => included.contains(parent)
              None => false
            }
            if spec.key == "level-up-panel" || parent_included {
              included[spec.key] = true
              mutations.push(mutation)
            }
          }
          _ => ()
        }
      }
    } else {
      mutations.push(Remove("level-up-panel"))
    }
  } else if next.level_up_visible && selections_replaced {
    let old_keys : Map[String, Selection] = Map([])
    let next_keys : Map[String, Selection] = Map([])
    for selection in previous.selections {
      old_keys[selection.key] = selection
    }
    for selection in next.selections {
      next_keys[selection.key] = selection
    }
    for selection in previous.selections {
      if !next_keys.contains(selection.key) {
        mutations.push(Remove("selection:" + selection.key))
      }
    }
    let mounted = generated_full_mount({ ..next, game_over_visible: false })
    for index, selection in next.selections {
      let key = "selection:" + selection.key
      match old_keys.get(selection.key) {
        None =>
          for mutation in mounted {
            match mutation {
              Mount(spec) if spec.key == key || spec.parent == Some(key) =>
                mutations.push(mutation)
              _ => ()
            }
          }
        Some(old) => {
          if old.label != selection.label {
            for mutation in mounted {
              match mutation {
                Mount(spec) if spec.key == key + ":label" =>
                  mutations.push(Update(spec))
                _ => ()
              }
            }
          }
          if old.icon != selection.icon {
            mutations.push(
              SetSource({ key: key + ":icon", value: selection.icon }),
            )
          }
          if old.background != selection.background {
            mutations.push(SetBackground({ key, value: selection.background }))
          }
        }
      }
      mutations.push(
        Move({
          key,
          parent: "selection-list",
          index: index.reinterpret_as_uint(),
        }),
      )
    }
  }
  if previous.game_over_visible != next.game_over_visible {
    if next.game_over_visible {
      let mounted = generated_full_mount({ ..next, level_up_visible: false })
      let included : Map[String, Bool] = Map([])
      for mutation in mounted {
        match mutation {
          Mount(spec) => {
            let parent_included = match spec.parent {
              Some(parent) => included.contains(parent)
              None => false
            }
            if spec.key == "game-over-panel" || parent_included {
              included[spec.key] = true
              mutations.push(mutation)
            }
          }
          _ => ()
        }
      }
    } else {
      mutations.push(Remove("game-over-panel"))
    }
  } else if next.game_over_visible {
    if previous.score != next.score {
      mutations.push(
        SetText({
          key: "final-score",
          value: "Final Score: " + next.score.to_string(),
        }),
      )
    }
    if previous.victory != next.victory {
      mutations.push(
        SetText({
          key: "game-over-title",
          value: if next.victory {
            "VICTORY!"
          } else {
            "GAME OVER"
          },
        }),
      )
    }
  }
  mutations
}

///|
pub fn mount(entity : UInt, state : SurvivorsUiState) -> Unit {
  if survivors_ui_states.contains(entity) {
    abort("Selene Entity is already mounted")
  }
  let seen : Map[String, Bool] = Map([])
  for selection in state.selections {
    if selection.key == "" || seen.contains(selection.key) {
      abort("survivors selections require unique, non-empty keys")
    }
    seen[selection.key] = true
  }
  match @tree.apply(entity, generated_full_mount(state)) {
    Ok(_) => survivors_ui_states[entity] = { state, }
    Err(error) => abort("Selene UI host rejected mount: " + error.message)
  }
}

///|
pub fn replace(
  entity : UInt,
  state : SurvivorsUiState,
) -> Unit {
  let record = survivors_ui_states.get(entity).unwrap()
  let previous = record.state
  let seen : Map[String, Bool] = Map([])
  for selection in state.selections {
    if selection.key == "" || seen.contains(selection.key) {
      abort("survivors selections require unique, non-empty keys")
    }
    seen[selection.key] = true
  }
  let mutations = state_mutations(previous, state, true)
  if mutations.length() > 0 {
    match @tree.apply(entity, mutations) {
      Ok(_) => ()
      Err(error) => abort("Selene UI host rejected replace: " + error.message)
    }
  }
  survivors_ui_states[entity] = { state, }
}

///|
pub fn apply(
  entity : UInt,
  patches : Array[SurvivorsUiPatch],
) -> Unit {
  let record = survivors_ui_states.get(entity).unwrap()
  let previous = record.state
  let mut selections = previous.selections.copy()
  for patch in patches {
    match patch {
      SelectionsReplace(values) => selections = values.copy()
      SelectionUpsert(value) => {
        let mut replaced = false
        for index, selection in selections {
          if selection.key == value.key {
            selections[index] = value
            replaced = true
            break
          }
        }
        if !replaced {
          selections.push(value)
        }
      }
      SelectionRemove(key) => {
        let retained : Array[Selection] = []
        for selection in selections {
          if selection.key != key {
            retained.push(selection)
          }
        }
        selections = retained
      }
      SelectionMove((key, destination)) => {
        let retained : Array[Selection] = []
        let mut moved : Selection? = None
        for selection in selections {
          if selection.key == key {
            moved = Some(selection)
          } else {
            retained.push(selection)
          }
        }
        guard moved is Some(value) else {
          abort("selection-move key does not exist: " + key)
        }
        if destination.reinterpret_as_int() > retained.length() {
          abort("selection-move index is out of range")
        }
        let reordered : Array[Selection] = []
        for index = 0; index <= retained.length(); index = index + 1 {
          if index == destination.reinterpret_as_int() {
            reordered.push(value)
          }
          if index < retained.length() {
            reordered.push(retained[index])
          }
        }
        selections = reordered
      }
    }
  }
  let seen : Map[String, Bool] = Map([])
  for selection in selections {
    if selection.key == "" || seen.contains(selection.key) {
      abort("survivors selections require unique, non-empty keys")
    }
    seen[selection.key] = true
  }
  let next = { ..previous, selections, }
  let mutations = state_mutations(previous, next, patches.length() > 0)
  if mutations.length() > 0 {
    match @tree.apply(entity, mutations) {
      Ok(_) => ()
      Err(error) =>
        abort("Selene UI host rejected patch batch: " + error.message)
    }
  }
  survivors_ui_states[entity] = { state: next }
}

///|
pub fn handle_event(
  entity : UInt,
  event : UiEvent,
) -> SurvivorsAction? {
  let state = survivors_ui_states.get(entity).unwrap().state
  match event {
    Click("restart") if state.game_over_visible => Some(Restart)
    Click(key) if state.level_up_visible && key.has_prefix("selection:") => {
      let selection_key = key["selection:".length():].to_owned()
      for selection in state.selections {
        if selection.key == selection_key {
          return Some(SelectPowerup(selection_key))
        }
      }
      None
    }
    _ => None
  }
}

///|
pub fn update() -> Unit {
  // This view currently advances only through replace/apply calls.
}

///|
pub fn unmount(entity : UInt) -> Unit {
  survivors_ui_states.remove(entity)
}
