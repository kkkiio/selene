<View xmlns="urn:selene:xaml:ui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:model="moonbit:KKKIIO/selene-xaml-survivors-example/model"
         x:Class="SurvivorsView"
         DataType="model:SurvivorsUiState"
         x:Name="survivorsHud" Width="480" Height="320">
  <Text x:Name="level" Position="Absolute" Left="16" Top="16"
           Width="124" Height="28" Text="{Binding Path=levelLabel}"
           Color="yellow" FontFamily="ThaleahFat" FontSize="24" ZIndex="101" />
  <Text x:Name="experience" Position="Absolute" Left="16" Top="50"
           Width="180" Height="28" Text="{Binding Path=experienceLabel}"
           Color="cyan" FontFamily="ThaleahFat" FontSize="24" ZIndex="101" />
  <Text x:Name="wave" Position="Absolute" Left="16" Top="84"
           Width="124" Height="28" Text="{Binding Path=waveLabel}"
           Color="orange" FontFamily="ThaleahFat" FontSize="24" ZIndex="101" />
  <Text x:Name="score" Position="Absolute" Left="140" Top="16"
           Width="200" Height="28" Text="{Binding Path=scoreLabel}"
           Color="white" FontFamily="ThaleahFat" FontSize="24"
           Align="Center" ZIndex="101" />
  <Text x:Name="timer" Position="Absolute" Left="340" Top="16"
           Width="124" Height="28" Text="{Binding Path=timerLabel}"
           Color="white" FontFamily="ThaleahFat" FontSize="24"
           Align="Right" ZIndex="101" />

  <If Condition="{Binding Path=levelUpVisible}">
    <If.Then>
      <View x:Name="levelUpPanel" Position="Absolute" Left="160" Top="40"
               Width="160" Height="250" Background="rgba(13, 170, 26, 1)"
               BorderColor="black" Border="1" Radius="10" ZIndex="102">
        <Text x:Name="levelUpTitle" Position="Absolute" Left="8" Top="20" Width="144" Height="36"
                 Text="LEVEL UP!" Color="gold" FontFamily="ThaleahFat"
                 FontSize="36" Align="Center" ZIndex="103" />
        <Flex x:Name="selectionList" Position="Absolute" Left="0" Top="76"
                 Width="160" Height="174" Direction="Column" Gap="20" ZIndex="103">
          <ItemsControl ItemsSource="{Binding Path=selections}" KeyPath="key">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="model:Selection">
                <Button x:Name="selectionButton" OnClick="select_powerup"
                           Width="160" Height="36"
                           Background="{Binding Path=background}"
                           BorderColor="black" Radius="8" Enabled="true" ZIndex="103">
                  <Image x:Name="icon" Position="Absolute" Left="8" Top="6"
                            Source="{Binding Path=icon}" Width="24" Height="24" Fit="Contain" ZIndex="104" />
                  <Text x:Name="label" Position="Absolute" Left="36" Top="8"
                           Width="116" Height="22" Text="{Binding Path=label}" Color="white"
                           FontFamily="ThaleahFat" FontSize="16" Align="Center" ZIndex="104" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Flex>
      </View>
    </If.Then>
  </If>

  <If Condition="{Binding Path=gameOverVisible}">
    <If.Then>
      <View x:Name="gameOverPanel" Position="Absolute" Left="140" Top="100"
               Width="200" Height="120" Background="rgba(0, 0, 0, 0.8)"
               BorderColor="white" Border="1" Radius="10" ZIndex="102">
        <Text x:Name="gameOverTitle" Position="Absolute" Left="10" Top="18" Width="180" Height="30"
                 Text="{Binding Path=gameOverTitle}" Color="gold"
                 FontFamily="ThaleahFat" FontSize="32" Align="Center" ZIndex="103" />
        <Text x:Name="finalScore" Position="Absolute" Left="8" Top="52" Width="184" Height="22"
                 Text="{Binding Path=finalScoreLabel}" Color="white"
                 FontFamily="ThaleahFat" FontSize="24" Align="Center" ZIndex="103" />
        <Button x:Name="restart" Position="Absolute" Left="10" Top="74"
                   Width="180" Height="40" OnClick="restart" Enabled="true"
                   Background="rgba(13, 167, 170, 1)" BorderColor="white"
                   Radius="8" ZIndex="103">
          <Text x:Name="restartLabel" Position="Absolute" Left="10" Top="8"
                   Width="160" Height="24" Text="RESTART" Color="white" FontFamily="ThaleahFat"
                   FontSize="24" Align="Center" ZIndex="104" />
        </Button>
      </View>
    </If.Then>
  </If>
</View>
