package selene:ui-host@0.1.0;

/// XAML-independent, batched mutation capability implemented by Selene.
///
/// The guest owns business state and reconciliation. The host owns the real
/// Selene entities and validates each mutation batch before committing it.
interface tree {
  enum node-kind {
    view,
    flex,
    text,
    image,
    button,
    scroll-view,
  }

  enum text-align {
    left,
    center,
    right,
  }

  enum image-fit {
    fill,
    contain,
    cover,
  }

  enum flex-direction {
    row,
    row-reverse,
    column,
    column-reverse,
  }

  variant layout-value {
    auto,
    px(f32),
    percent(f32),
  }

  variant visual-state-value {
    string-value(string),
    bool-value(bool),
    double-value(f64),
    int-value(s32),
    layout-value-value(layout-value),
  }

  record visual-state-setter {
    target: string,
    property: string,
    value: visual-state-value,
  }

  record visual-state-definition {
    name: string,
    setters: list<visual-state-setter>,
  }

  record visual-transition {
    %from: option<string>,
    to: option<string>,
    duration: f64,
    delay: f64,
    easing: string,
  }

  record visual-state-group {
    order: s32,
    name: string,
    current: string,
    interaction: bool,
    states: list<visual-state-definition>,
    transitions: list<visual-transition>,
  }

  record node-style {
    absolute: bool,
    left: f32,
    top: f32,
    width: layout-value,
    height: layout-value,
    margin-left: f32,
    margin-top: f32,
    margin-right: f32,
    margin-bottom: f32,
    padding-left: f32,
    padding-top: f32,
    padding-right: f32,
    padding-bottom: f32,
    background: string,
    border-color: string,
    border: f32,
    radius: f32,
    outline-color: string,
    outline-width: f32,
    outline-offset: f32,
    color: string,
    font-family: string,
    font-size: f32,
    bold: bool,
    align: text-align,
    wrap: bool,
    z-index: s32,
    fit: image-fit,
    direction: flex-direction,
    flex-basis: layout-value,
    flex-grow: f32,
    flex-shrink: f32,
    row-gap: f32,
    column-gap: f32,
    horizontal-scroll: bool,
    vertical-scroll: bool,
    scrollbar-width: f32,
  }

  record node-spec {
    key: string,
    parent: option<string>,
    kind: node-kind,
    text: string,
    source: string,
    active: bool,
    enabled: bool,
    focusable: bool,
    style: node-style,
    visual-state-groups: list<visual-state-group>,
  }

  record text-mutation {
    key: string,
    value: string,
  }

  record bool-mutation {
    key: string,
    value: bool,
  }

  record f32-mutation {
    key: string,
    value: f32,
  }

  record move-mutation {
    key: string,
    parent: string,
    index: u32,
  }

  variant tree-mutation {
    mount(node-spec),
    update(node-spec),
    set-text(text-mutation),
    set-source(text-mutation),
    set-background(text-mutation),
    set-active(bool-mutation),
    set-enabled(bool-mutation),
    set-top(f32-mutation),
    move(move-mutation),
    remove(string),
  }

  record host-error {
    code: string,
    message: string,
  }

  apply: func(entity: u32, mutations: list<tree-mutation>) -> result<_, host-error>;
}
