///|
pub(all) struct ComponentGuestTarget {
  event_type : String
  action_type : String
  tree_package : String
} derive(Eq, Debug)

///|
pub(all) suberror ComponentEmitterError {
  InvalidArtifactPath(String)
} derive(Eq, Debug)

///|
pub impl Show for ComponentEmitterError with fn output(self, logger) {
  match self {
    InvalidArtifactPath(message) => logger.write_string(message)
  }
}

///|
pub fn emit(
  ir : @viewir.ViewIR,
  target : ComponentGuestTarget,
  source_uri : String,
  source : String,
  contract_uri : String,
  contract_source : String,
) -> @generator_io.GeneratedPackage raise {
  let normalized_source = normalize_component_artifact_path(source_uri)
  let normalized_contract = normalize_component_artifact_path(contract_uri)
  let source_hash = component_sha256_text(source)
  let contract_hash = component_sha256_text(contract_source)
  let header =
    $|// Generated by selene-xaml@0.1.0 Component emitter. DO NOT EDIT.
    $|// input user \{normalized_source} sha256=\{source_hash}
    $|// input wit \{normalized_contract} sha256=\{contract_hash}
    $|
    $|
  let emitted = emit_component_source(ir, target, header)
  let source_map = emit_component_source_map(
    normalized_source,
    emitted.mappings,
  )
  let owned : Array[@generator_io.GeneratedFile] = [
    { path: "guest.generated.mbt", content: emitted.source },
    { path: "guest.generated.mbt.map.json", content: source_map },
  ]
  let lock = emit_component_lock(
    ir, target, normalized_source, source_hash, normalized_contract, contract_hash,
    owned,
  )
  { files: owned + [{ path: "selene-xaml.lock.json", content: lock }] }
}

///|
fn normalize_component_artifact_path(
  path : String,
) -> String raise ComponentEmitterError {
  let normalized = path.replace_all(old="\\", new="/")
  if normalized == "" ||
    normalized.has_prefix("/") ||
    (normalized.length() >= 2 && normalized[1] == ':') {
    raise ComponentEmitterError::InvalidArtifactPath(
      "generator input paths must be repository-relative: " + path,
    )
  }
  let segments : Array[String] = []
  for raw_segment in normalized.split("/") {
    let segment = raw_segment.to_owned()
    if segment == "" || segment == "." {
      continue
    }
    if segment == ".." {
      if segments.length() == 0 {
        raise ComponentEmitterError::InvalidArtifactPath(
          "generator input path escapes the repository: " + path,
        )
      }
      ignore(segments.pop())
      continue
    }
    segments.push(segment)
  }
  if segments.length() == 0 {
    raise ComponentEmitterError::InvalidArtifactPath(
      "generator input paths must name a repository artifact: " + path,
    )
  }
  segments.join("/")
}

///|
fn component_sha256_text(source : String) -> String {
  @crypto.bytes_to_hex_string(
    @crypto.sha256(@encoding.encode(@encoding.Encoding::UTF8, source)),
  )
}

///|
fn emit_component_source_map(
  source_uri : String,
  mappings : Array[ComponentSourceMapping],
) -> String {
  if mappings.length() == 0 {
    return (
      #|{
      #|  "mappings": []
      #|}
      #|
    )
  }
  let output = StringBuilder::new()
  output <+
    #|{
    #|  "mappings": [
  for index, mapping in mappings {
    if index > 0 {
      output <+ ",\n"
    }
    output <+
      $|    {
      $|      "source": \{source_uri.escape()},
      $|      "original_offset": \{mapping.original_offset},
      $|      "generated_offset": \{mapping.generated_offset},
      $|      "length": \{mapping.length}
      $|    }
  }
  output <+ "\n"
  output <+
    #|  ]
    #|}
    #|
  output.to_string()
}

///|
fn emit_component_lock(
  ir : @viewir.ViewIR,
  target : ComponentGuestTarget,
  source_uri : String,
  source_hash : String,
  contract_uri : String,
  contract_hash : String,
  files : Array[@generator_io.GeneratedFile],
) -> String {
  let output = StringBuilder::new()
  output <+
    $|{
    $|  "format_version": 1,
    $|  "generator": "selene-xaml@0.1.0",
    $|  "target": "component-guest",
    $|  "view": \{ir.identity.view_name.escape()},
    $|  "identity": "selene-entity-u32",
    $|  "inputs": [
    $|    { "owner": "user", "path": \{source_uri.escape()}, "sha256": "\{source_hash}" },
    $|    { "owner": "wit", "path": \{contract_uri.escape()}, "sha256": "\{contract_hash}" }
    $|  ],
    $|  "host_capability": { "package": \{target.tree_package.escape()}, "operations": ["apply"] },
    $|  "outputs": [
  for index, file in files {
    let suffix = if index + 1 < files.length() { ",\n" } else { "\n" }
    output <+
      $|    { "owner": "selene-xaml", "path": \{file.path.escape()}, "sha256": "\{component_sha256_text(file.content)}" }\{suffix}
  }
  output <+
    #|  ],
    #|  "lock_path": "selene-xaml.lock.json"
    #|}
    #|
  output.to_string()
}
