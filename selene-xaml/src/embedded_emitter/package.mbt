///|
pub(all) suberror EmbeddedEmitterError {
  InvalidArtifactPath(String)
} derive(Eq, Debug)

///|
pub impl Show for EmbeddedEmitterError with fn output(self, logger) {
  match self {
    InvalidArtifactPath(message) => logger.write_string(message)
  }
}

///|
pub fn emit(
  ir : @viewir.ViewIR,
  source_uri : String,
  source : String,
  contract_uri : String,
  contract_source : String,
) -> @generator_io.GeneratedPackage raise {
  let normalized_source = normalize_artifact_path(source_uri)
  let normalized_contract = normalize_artifact_path(contract_uri)
  let source_hash = sha256_text(source)
  let contract_hash = sha256_text(contract_source)
  let plan = ir
  let schema = ir.contract
  let analysis = ir.contract
  let action_shapes : Map[String, Bool] = Map([])
  for action in ir.action_routes {
    action_shapes[action.variant_name] = action.collection_path is Some(_)
  }
  let action_names = action_shapes.keys().collect()
  action_names.sort()
  let public_action_abi = StringBuilder::new()
  public_action_abi <+ "action \{plan.identity.view_name}Action {\n"
  for name in action_names {
    public_action_abi <+ "  \{name}"
    if action_shapes[name] {
      public_action_abi <+ "(String)"
    }
    public_action_abi <+ "\n"
  }
  public_action_abi <+ "}\n"
  let moon_pkg =
    $|import {
    $|  "\{ir.contract.package_path}",
    $|  "KKKIIO/selene/app",
    $|  "KKKIIO/selene/ecs",
    $|  "KKKIIO/selene/entity",
    $|  "KKKIIO/selene/event",
    $|  "KKKIIO/selene/system",
    $|  "KKKIIO/selene_xaml_runtime/component_host",
    $|  "KKKIIO/selene_xaml_runtime/ui_host",
    $|  "moonbitlang/core/string",
    $|}
    $|
    $|supported_targets = "native+js"
    $|
  let generated_header =
    $|// Generated by selene-xaml@0.1.0. DO NOT EDIT.
    $|// lock-format: 1
    $|// input user \{normalized_source} sha256=\{source_hash}
    $|// input moon-info \{normalized_contract} sha256=\{contract_hash}
    $|
    $|
  let state_source = emit_state_source(schema, analysis, generated_header)
  let emitted_view = emit_view_source(plan, generated_header)
  let source_map = emit_source_map(normalized_source, emitted_view.mappings)
  let owned : Array[@generator_io.GeneratedFile] = [
    { path: "moon.pkg", content: moon_pkg },
    { path: "state.generated.mbt", content: state_source },
    { path: "view.generated.mbt", content: emitted_view.source },
    { path: "view.generated.mbt.map.json", content: source_map },
  ]
  let abi_fingerprint = sha256_text(
    (
      $|selene-xaml-abi-v2
      $|runtime KKKIIO/selene
      $|\{plan.identity.view_name}
      $|\{plan.contract.model_type.package_path}
      $|\{contract_source}
      $|\{public_action_abi}
      $|selene-ui-host@0.1.0
      $|mount
      $|apply
      $|
    ),
  )
  let lock = emit_lock(
    normalized_source, source_hash, normalized_contract, contract_hash, plan, schema,
    abi_fingerprint, owned,
  )
  { files: owned + [{ path: "selene-xaml.lock.json", content: lock }] }
}

///|
fn normalize_artifact_path(path : String) -> String raise EmbeddedEmitterError {
  let normalized = path.replace_all(old="\\", new="/")
  if normalized == "" ||
    normalized.has_prefix("/") ||
    (normalized.length() >= 2 && normalized[1] == ':') {
    raise EmbeddedEmitterError::InvalidArtifactPath(
      "generator input paths must be repository-relative: " + path,
    )
  }
  let segments : Array[String] = []
  for raw_segment in normalized.split("/") {
    let segment = raw_segment.to_owned()
    if segment == "" || segment == "." {
      continue
    }
    if segment == ".." {
      if segments.length() == 0 {
        raise EmbeddedEmitterError::InvalidArtifactPath(
          "generator input path escapes the repository: " + path,
        )
      }
      ignore(segments.pop())
      continue
    }
    segments.push(segment)
  }
  if segments.length() == 0 {
    raise EmbeddedEmitterError::InvalidArtifactPath(
      "generator input paths must name a repository artifact: " + path,
    )
  }
  segments.join("/")
}

///|
fn sha256_text(source : String) -> String {
  @crypto.bytes_to_hex_string(
    @crypto.sha256(@encoding.encode(@encoding.Encoding::UTF8, source)),
  )
}

///|
fn emit_state_source(
  schema : @viewir.IRBusinessContract,
  analysis : @viewir.IRBusinessContract,
  generated_header : String,
) -> String {
  let output = StringBuilder::new()
  output <+ "\{generated_header}"
  let reachable : Map[String, Bool] = Map([])
  let pending = [analysis.state.name, analysis.model_type.type_name]
  match analysis.patch {
    Some(patch) => pending.push(patch.name)
    None => ()
  }
  while pending.length() > 0 {
    let name = pending.pop().unwrap()
    if reachable.contains(name) {
      continue
    }
    if !schema.structs.contains(name) &&
      !schema.enums.contains(name) &&
      !schema.aliases.contains(name) {
      continue
    }
    reachable[name] = true
    let references : Array[String] = []
    match schema.structs.get(name) {
      Some(definition) =>
        for field in definition.fields {
          references.push(field.field_type)
        }
      None => ()
    }
    match schema.enums.get(name) {
      Some(definition) =>
        for variant in definition.variants {
          match variant.payload {
            Some(payload) => references.push(payload)
            None => ()
          }
        }
      None => ()
    }
    match schema.aliases.get(name) {
      Some(target) => references.push(target)
      None => ()
    }
    for reference in references {
      let normalized = reference
        .replace_all(old="[", new=" ")
        .replace_all(old="]", new=" ")
        .replace_all(old="(", new=" ")
        .replace_all(old=")", new=" ")
        .replace_all(old=",", new=" ")
        .replace_all(old="?", new=" ")
        .replace_all(old="&", new=" ")
        .replace_all(old="->", new=" ")
      for candidate in normalized.split(" ") {
        let candidate = candidate.trim().to_owned()
        if candidate != "" &&
          (
            schema.structs.contains(candidate) ||
            schema.enums.contains(candidate) ||
            schema.aliases.contains(candidate)
          ) &&
          !reachable.contains(candidate) {
          pending.push(candidate)
        }
      }
    }
  }
  let names = reachable.keys().collect()
  names.sort()
  let package_alias = analysis.model_type.package_alias
  for name in names {
    output <+
      $|///|
      $|pub type \{name} = @\{package_alias}.\{name}
      $|
      $|
  }
  output.to_string().trim_end().to_owned() + "\n"
}

///|
fn emit_source_map(
  source_uri : String,
  mappings : Array[EmbeddedSourceMapping],
) -> String {
  if mappings.length() == 0 {
    return (
      #|{
      #|  "mappings": []
      #|}
      #|
    )
  }
  let output = StringBuilder::new()
  output <+
    #|{
    #|  "mappings": [
  for index, mapping in mappings {
    if index > 0 {
      output <+ ",\n"
    }
    output <+
      $|    {
      $|      "source": \{source_uri.escape()},
      $|      "original_offset": \{mapping.original_offset},
      $|      "generated_offset": \{mapping.generated_offset},
      $|      "length": \{mapping.length}
      $|    }
  }
  output <+ "\n"
  output <+
    #|  ]
    #|}
    #|
  output.to_string()
}

///|
fn emit_lock(
  source_uri : String,
  source_hash : String,
  mbti_uri : String,
  mbti_hash : String,
  plan : @viewir.ViewIR,
  schema : @viewir.IRBusinessContract,
  abi_fingerprint : String,
  files : Array[@generator_io.GeneratedFile],
) -> String {
  let output = StringBuilder::new()
  output <+
    $|{
    $|  "format_version": 1,
    $|  "generator": "selene-xaml@0.1.0",
    $|  "runtime": "KKKIIO/selene",
    $|  "inputs": [
    $|    { "owner": "user", "path": \{source_uri.escape()}, "sha256": "\{source_hash}" },
    $|    { "owner": "moon-info", "path": \{mbti_uri.escape()}, "sha256": "\{mbti_hash}" }
    $|  ],
    $|  "resolved_contract": { "kind": "mbti", "path": \{mbti_uri.escape()}, "package": \{schema.package_path.escape()}, "sha256": "\{mbti_hash}" },
    $|  "requested_outputs": ["moon.pkg", "state.generated.mbt", "view.generated.mbt", "view.generated.mbt.map.json", "selene-xaml.lock.json"],
    $|  "output_naming": { "package_directory": ".", "state": "state.generated.mbt", "view": "view.generated.mbt", "source_map": "view.generated.mbt.map.json", "lock": "selene-xaml.lock.json" },
    $|  "package_alias": { "alias": \{plan.contract.model_type.package_alias.escape()}, "package": \{plan.contract.model_type.package_path.escape()} },
    $|  "imported_sidecars": [],
    $|  "host_capability": { "package": "KKKIIO/selene_xaml_runtime/ui_host", "contract": "component-host", "version": "0.1.0", "operations": ["mount", "apply"] },
    $|  "abi_fingerprint": "sha256:\{abi_fingerprint}",
    $|  "outputs": [
  for index, file in files {
    output <+
      $|    { "owner": "selene-xaml", "path": \{file.path.escape()}, "sha256": "\{sha256_text(file.content)}" }
    if index + 1 < files.length() {
      output <+ ","
    }
    output <+ "\n"
  }
  output <+
    #|  ],
    #|  "lock_path": "selene-xaml.lock.json"
    #|}
    #|
  output.to_string()
}

///|
