        padding_right: 0.0,
        padding_bottom: 0.0,
        background: "",
        border_color: "",
        border: 0.0,
        radius: 0.0,
        outline_color: "",
        outline_width: 0.0,
        outline_offset: 0.0,
        color: "#c7a986",
        font_family: "",
        font_size: 14,
        bold: false,
        align: @ui_view.TextAlign::Left,
        wrap: true,
        z_index: 0,
        fit: @ui_view.ImageFit::Fill,
        direction: @ui_view.FlexDirection::Column,
        flex_basis: @ui_view.LayoutValue::Auto,
        flex_grow: 0.0,
        flex_shrink: 1.0,
        row_gap: 0.0,
        column_gap: 0.0,
        grid_rows: [],
        grid_columns: [],
        grid_auto_flow: @ui_view.GridAutoFlow::Row,
        grid_row: None,
        grid_column: None,
        grid_row_span: 1,
        grid_column_span: 1,
        horizontal_scroll: false,
        vertical_scroll: false,
        scrollbar_width: 0.0,
      },
      visual_state_groups: [],
    })
  }
  nodes
}

///|
pub fn InventoryView::mount(
  entity : @entity.Entity,
  model : InventoryUiState,
) -> Unit raise InventoryViewError {
  if !entity.is_alive() {
    raise DeadEntity
  }
  if generated_view_records.contains(entity) {
    raise AlreadyMounted
  }
  let view_model = generated_compute_view_model(model)
  let desired = generated_specs(view_model)
  let host = @ui_view.ViewHost::new()
  host.mount(entity, desired) catch {
    error => raise Host(error)
  }
  generated_view_records[entity] = { model, view_model, specs: desired }
}

///|
pub fn InventoryView::replace(
  entity : @entity.Entity,
  model : InventoryUiState,
) -> Unit raise InventoryViewError {
  let record = match generated_view_records.get(entity) {
    Some(value) => value
    None => raise NotMounted
  }
  if !entity.is_alive() {
    generated_view_records.remove(entity)
    raise DeadEntity
  }
  let view_model = generated_compute_view_model(model)
  let desired = generated_specs(view_model)
  let mutations = generated_diff(record.specs, desired)
  if mutations.length() > 0 {
    let host = @ui_view.ViewHost::new()
    host.apply(entity, mutations) catch {
      error => raise Host(error)
    }
  }
  record.model = model
  record.view_model = view_model
  record.specs = desired
}

///|
pub fn InventoryView::apply(
  entity : @entity.Entity,
  patches : Array[InventoryUiPatch],
) -> Unit raise InventoryViewError {
  let record = match generated_view_records.get(entity) {
    Some(value) => value
    None => raise NotMounted
  }
  let mut items = record.model.items.copy()
  for patch in patches {
    match patch {
      InventoryUiPatch::ItemsReplace(values) => items = values.copy()
      InventoryUiPatch::ItemUpsert(value) => {
        let mut replaced = false
        for index, current in items {
          if current.id == value.id {
            items[index] = value
            replaced = true
            break
          }
        }
        if !replaced {
          items.push(value)
        }
      }
      InventoryUiPatch::ItemRemove(key) => {
        let mut removed = false
        for value in items {
          if value.id == key {
            removed = true
            break
          }
        }
        if !removed {
          raise InvalidPatch(
            "patch remove key does not exist: " + key.to_string(),
          )
        }
        items = items.filter(value => value.id != key)
      }
      InventoryUiPatch::ItemMove((key, destination)) => {
        let retained : Array[InventoryItem] = []
        let mut moved : InventoryItem? = None
        for value in items {
          if value.id == key {
            moved = Some(value)
          } else {
            retained.push(value)
          }
        }
        guard moved is Some(value) else {
          raise InvalidPatch(
            "patch move key does not exist: " + key.to_string(),
          )
        }
        let destination = destination.reinterpret_as_int()
        if destination < 0 || destination > retained.length() {
          raise InvalidPatch("patch move destination is out of range")
        }
        retained.insert(destination, value)
        items = retained
      }
    }
  }
  InventoryView::replace(entity, { ..record.model, items, })
}

///|
fn generated_handle_event(
  record : GeneratedViewRecord,
  event : @ui_view.UiEvent,
) -> InventoryViewAction? {
  if !generated_contains(record.specs, event.key) {
    return None
  }
  if event.kind == @ui_view.UiEventKind::Click {
    for generated_action_item in record.view_model.tabs {
      let generated_action_key = generated_action_item.id
      let generated_action_node_key = "inventory-header/tabs:\{generated_action_key}/tab-button"
      if event.key == generated_action_node_key {
        return Some(InventoryViewAction::SelectTab(generated_action_key))
      }
    }
  }
  if event.kind == @ui_view.UiEventKind::Click {
    for generated_action_item in record.view_model.items {
      let generated_action_key = generated_action_item.id
      let generated_action_node_key = "pack-grid/items:\{generated_action_key}/item-button-wide"
      if event.key == generated_action_node_key {
        return Some(InventoryViewAction::SelectItem(generated_action_key))
      }
    }
  }
  if event.kind == @ui_view.UiEventKind::Focus {
    for generated_action_item in record.view_model.items {
      let generated_action_key = generated_action_item.id
      let generated_action_node_key = "pack-grid/items:\{generated_action_key}/item-button-wide"
      if event.key == generated_action_node_key {
        return Some(InventoryViewAction::FocusItem(generated_action_key))
      }
    }
  }
  if event.kind == @ui_view.UiEventKind::Click {
    for generated_action_item in record.view_model.equipment {
      let generated_action_key = generated_action_item.slot
      let generated_action_node_key = "details/equipment:\{generated_action_key}/equipment-button-wide"
      if event.key == generated_action_node_key {
        return Some(InventoryViewAction::SelectEquipment(generated_action_key))
      }
    }
  }
  if event.kind == @ui_view.UiEventKind::Click {
    for generated_action_item in record.view_model.items {
      let generated_action_key = generated_action_item.id
      let generated_action_node_key = "pack-grid-narrow/items:\{generated_action_key}/item-button-narrow"
      if event.key == generated_action_node_key {
        return Some(InventoryViewAction::SelectItem(generated_action_key))
      }
    }
  }
  if event.kind == @ui_view.UiEventKind::Focus {
    for generated_action_item in record.view_model.items {
      let generated_action_key = generated_action_item.id
      let generated_action_node_key = "pack-grid-narrow/items:\{generated_action_key}/item-button-narrow"
      if event.key == generated_action_node_key {
        return Some(InventoryViewAction::FocusItem(generated_action_key))
      }
    }
  }
  if event.kind == @ui_view.UiEventKind::Click {
    for generated_action_item in record.view_model.equipment {
      let generated_action_key = generated_action_item.slot
      let generated_action_node_key = "narrow-panel/equipment:\{generated_action_key}/equipment-button-narrow"
      if event.key == generated_action_node_key {
        return Some(InventoryViewAction::SelectEquipment(generated_action_key))
      }
    }
  }
  None
}

///|
fn generated_route_events(_world : @ecs.World) -> Unit {
  let dead : Array[@entity.Entity] = []
  for entity, _ in generated_view_records {
    if !entity.is_alive() {
      dead.push(entity)
    }
  }
  for entity in dead {
    generated_view_records.remove(entity)
  }
  for raw in generated_event_reader.read(@ui_view.view_event_bus) {
    match generated_view_records.get(raw.entity) {
      Some(record) =>
        match generated_handle_event(record, raw.event) {
          Some(action) => action_event_bus.send({ entity: raw.entity, action })
          None => ()
        }
      None => ()
    }
  }
}

///|
pub fn plugin(app : @app.App) -> @app.App {
  app
  .add_plugin(@ui_view.plugin)
  .add_message(action_event_bus)
  .add_system(
    @system.PostUpdate,
    generated_route_events,
    system_name="selene_xaml_InventoryView_events",
  )
}
